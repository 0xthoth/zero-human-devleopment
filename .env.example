# Project Identity (unique per project — used for container names + Traefik routing)
PROJECT_NAME=0xthoth

# Dev Server
SSH_PORT=2222
DEV_USER=dev
DEV_USER_PASSWORD=changeme

# Git Identity (used by agents for commits)
GIT_USER_NAME=project-bot
GIT_USER_EMAIL=bot@example.com
# Note: Each agent overrides git identity via their AGENTS.md config

# Node environment — use "development" so pnpm installs devDependencies
NODE_ENV=development

# API Keys
ANTHROPIC_API_KEY=
GITHUB_TOKEN=

# Traefik (optional, for HTTPS)
# ACME_EMAIL=admin@example.com
