# Skills (exclude installed skills, but keep .clawhub tracking)
.openclaw/skills/*/
!.openclaw/skills/.clawhub/
.openclaw/workspace-**/skills/*/
!.openclaw/workspace-**/skills/.clawhub/

# OpenClaw Live Config (use template instead)
.openclaw/openclaw.json
.openclaw/openclaw.json.bak
.openclaw/openclaw.json.backup.*
.openclaw/openclaw.json.project-backup
.openclaw/update-check.json

# OpenClaw session data (contains auth tokens)
.openclaw/agents/*/sessions/

# Workspace Runtime Data (exclude personal data)
.openclaw/workspace-*/.openclaw/workspace-state.json
.openclaw/workspace-*/memory/

# Keep Template Structure but Exclude Personal Data
# Workspaces are committed, but runtime state is excluded above

