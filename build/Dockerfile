FROM ubuntu:24.04

ARG DEV_USER=dev
ARG DEV_USER_PASSWORD=changeme

ENV DEBIAN_FRONTEND=noninteractive

# Base packages
RUN apt-get update && apt-get install -y --fix-missing \
    openssh-server curl git tmux sudo python3 python3-pip \
    vim wget ca-certificates gnupg htop jq \
    && rm -rf /var/lib/apt/lists/*

# Node.js 22 LTS
RUN mkdir -p /etc/apt/keyrings \
    && curl -fsSL https://deb.nodesource.com/gpgkey/nodesource-repo.gpg.key \
       | gpg --dearmor -o /etc/apt/keyrings/nodesource.gpg \
    && echo "deb [signed-by=/etc/apt/keyrings/nodesource.gpg] \
       https://deb.nodesource.com/node_22.x nodistro main" \
       | tee /etc/apt/sources.list.d/nodesource.list \
    && apt-get update && apt-get install -y nodejs \
    && rm -rf /var/lib/apt/lists/* \
    && corepack enable \
    && corepack prepare pnpm@9.15.4 --activate

# GitHub CLI
RUN curl -fsSL https://cli.github.com/packages/githubcli-archive-keyring.gpg \
      | dd of=/usr/share/keyrings/githubcli-archive-keyring.gpg \
    && chmod go+r /usr/share/keyrings/githubcli-archive-keyring.gpg \
    && echo "deb [arch=$(dpkg --print-architecture) \
       signed-by=/usr/share/keyrings/githubcli-archive-keyring.gpg] \
       https://cli.github.com/packages stable main" \
       | tee /etc/apt/sources.list.d/github-cli.list > /dev/null \
    && apt-get update && apt-get install -y gh \
    && rm -rf /var/lib/apt/lists/*

# code-server (browser IDE)
RUN curl -fsSL https://code-server.dev/install.sh | sh

# Create dev user with UID 1000 and passwordless sudo
RUN userdel -r ubuntu 2>/dev/null || true \
    && useradd -m -s /bin/bash --uid 1000 ${DEV_USER} \
    && echo "${DEV_USER}:${DEV_USER_PASSWORD}" | chpasswd \
    && echo "${DEV_USER} ALL=(ALL) NOPASSWD:ALL" >> /etc/sudoers

# SSH hardening
RUN mkdir /var/run/sshd \
    && sed -i 's/#PasswordAuthentication yes/PasswordAuthentication yes/' /etc/ssh/sshd_config \
    && sed -i 's/#PermitRootLogin prohibit-password/PermitRootLogin no/' /etc/ssh/sshd_config \
    && echo "AllowUsers ${DEV_USER}" >> /etc/ssh/sshd_config

COPY code-server-config.yaml /etc/code-server-config.yaml
COPY start.sh /start.sh
RUN chmod +x /start.sh

EXPOSE 22 8080
CMD ["/start.sh"]
